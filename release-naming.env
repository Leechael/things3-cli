# Copy to repo root and customize.
# Source of truth for release naming used by docs/scripts/workflows.

CLI_NAME=things3-cli
BINARY_NAME=things3-cli
TAG_PREFIX=v
ARTIFACT_GLOB=things3-cli-*.tar.gz
BUILD_TARGET=./cmd/things3-cli

# Full package path to the Version variable for ldflags embedding
VERSION_VAR_PATH=github.com/Leechael/things3--cli/pkg/version.Version
